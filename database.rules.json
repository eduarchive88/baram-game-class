{
  "rules": {
    "sessions": {
      "$sessionCode": {
        ".read": "auth != null",
        "is_active": { ".write": "auth != null && auth.token.email_verified == true" },
        "isActive": { ".write": "auth != null && auth.token.email_verified == true" },
        "environment": { ".write": "auth != null && auth.token.email_verified == true" },
        "teacher_online": { ".write": "auth != null && auth.token.email_verified == true" },
        "students": { ".write": "auth != null && auth.token.email_verified == true" },
        
        "events": {
          ".write": "auth != null && (data.parent().child('is_active').val() === true || auth.token.email_verified == true)"
        },
        
        "maps": {
          "$mapId": {
            "players": {
              ".write": "auth != null && (root.child('sessions').child($sessionCode).child('is_active').val() === true || auth.token.email_verified == true)"
            },
            "master": {
              ".write": "auth != null && (root.child('sessions').child($sessionCode).child('is_active').val() === true || auth.token.email_verified == true)"
            }
          }
        }
      }
    },
    "userData": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "nicknames": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    ".read": false,
    ".write": false
  }
}